{
  "deviceOrientation": "portrait",
  "showStatusBar": false,
  "networkTimeout": {
    "request": 15000,
    "connectSocket": 15000,
    "uploadFile": 15000,
    "downloadFile": 15000
  },
  "subpackages": [
    {
      "name": "phaser",
      "root": "libs/",
      "independent": false
    },
    {
      "name": "images",
      "root": "assets/images/",
      "independent": false
    },
    {
      "name": "sounds",
      "root": "assets/sounds/",
      "independent": false
    }
  ],
  "workers": "",
  "requiredBackgroundModes": [],
  "plugins": {},
  "preload": true,
  "optimization": {
    "subPackageIndependent": false
  },
  "launchScene": "default",
  "entryPagePath": "game.js",
  "window": {
    "navigationBarTextStyle": "white",
    "navigationStyle": "custom",
    "backgroundTextStyle": "light",
    "backgroundColor": "#4EC0CA",
    "backgroundColorTop": "#4EC0CA",
    "backgroundColorBottom": "#4EC0CA",
    "navigationBarBackgroundColor": "#4EC0CA",
    "navigationBarTitleText": "四季 Flappy Bird"
  },
  "renderer": "canvas",
  "resizable": false,
  "disableScroll": true,
  "disableABTest": true,
  "singlePage": {
    "navigationBarCustomize": "always"
  }
}